{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "out-tsc/lib",
    "tsBuildInfoFile": "out-tsc/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["vitest.config.ts", "tsdown.config.ts", "src/**/*.spec.ts"],
  "references": [
    { "path": "../contract/tsconfig.lib.json" },
    { "path": "../http/tsconfig.lib.json" }
  ]
}
