{
  "name": "@localsink/test-harness",
  "version": "0.0.0",
  "description": "In-process server + DB harness for transport integration tests.",
  "keywords": [
    "integration-tests",
    "localsink",
    "log-transport",
    "logging",
    "testing",
    "vitest"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localsink/localsink.git",
    "directory": "packages/test-harness"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@localsink/source": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -b .",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "localsink": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
