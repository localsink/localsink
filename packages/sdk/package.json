{
  "name": "@localsink/sdk",
  "version": "0.0.0",
  "description": "SDK for sending logs to localsink programmatically.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localsink/localsink.git"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@localsink/source": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@localsink/contract": "workspace:*",
    "@localsink/http": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  }
}
