{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "out-tsc/lib",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": false,
    "moduleDetection": "force"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "references": [{ "path": "../contract/tsconfig.lib.json" }]
}
