{
  "name": "@localsink/sdk",
  "version": "0.0.0",
  "description": "SDK for sending logs to localsink programmatically.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/localsink/localsink"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@localsink/contract": "workspace:*",
    "@localsink/http": "workspace:*"
  }
}
