{
  "name": "@localsink/test-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Private in-process server + DB harness for transport integration tests.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localsink/localsink.git"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "localsink": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  }
}
