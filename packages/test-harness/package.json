{
  "name": "@localsink/test-harness",
  "version": "0.0.0",
  "private": true,
  "description": "Private in-process server + DB harness for transport integration tests.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/localsink/localsink"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@libsql/client": "catalog:",
    "drizzle-orm": "catalog:",
    "localsink": "workspace:*"
  }
}
