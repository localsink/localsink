{
  "name": "@localsink/winston",
  "version": "0.0.0",
  "description": "Winston transport for localsink.",
  "keywords": [
    "localsink",
    "log-transport",
    "logging",
    "observability",
    "winston",
    "winston-transport"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localsink/localsink.git",
    "directory": "packages/winston"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@localsink/source": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run",
    "integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@localsink/sdk": "workspace:*",
    "winston-transport": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@localsink/test-harness": "workspace:*",
    "winston": "catalog:"
  },
  "peerDependencies": {
    "winston": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
