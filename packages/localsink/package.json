{
  "name": "localsink",
  "version": "0.0.0",
  "description": "Local-first log sink with a searchable UI and API (reserved).",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localsink/localsink.git"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@localsink/source": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run",
    "dev": "node --watch --watch-path=src src/server.ts",
    "start": "node src/server.ts",
    "drizzle-kit:push": "drizzle-kit push",
    "drizzle-kit:generate": "drizzle-kit generate",
    "drizzle-kit:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/mcp": "catalog:",
    "@hono/node-server": "catalog:",
    "@hono/zod-validator": "catalog:",
    "@libsql/client": "catalog:",
    "@localsink/contract": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
