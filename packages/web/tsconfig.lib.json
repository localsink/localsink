{
  "extends": [
    "@tsconfig/strictest/tsconfig.json",
    "@tsconfig/vite-react/tsconfig.json"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "out-tsc/lib",
    "tsBuildInfoFile": "out-tsc/tsconfig.lib.tsbuildinfo",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "customConditions": ["@localsink/source"],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.spec.tsx"],
  "references": []
}
