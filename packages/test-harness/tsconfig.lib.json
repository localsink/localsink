{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "out-tsc/lib",
    "tsBuildInfoFile": "out-tsc/tsconfig.lib.tsbuildinfo",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["vitest.config.ts", "src/**/*.spec.ts"],
  "references": [{ "path": "../localsink/tsconfig.lib.json" }]
}
