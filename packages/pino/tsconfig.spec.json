{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "out-tsc/spec",
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "rewriteRelativeImportExtensions": false,
    "allowImportingTsExtensions": true
