{
  "name": "@localsink/console",
  "version": "0.0.0",
  "description": "Console transport for forwarding console.* output to localsink (reserved).",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/localsink/localsink"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run",
    "integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@localsink/sdk": "workspace:*"
  },
  "devDependencies": {
    "@localsink/test-harness": "workspace:*"
  }
}
