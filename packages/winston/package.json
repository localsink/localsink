{
  "name": "@localsink/winston",
  "version": "0.0.0",
  "description": "Winston transport for localsink (reserved).",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/localsink/localsink"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -b .",
    "lint": "oxlint .",
    "test": "vitest run",
    "integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@localsink/sdk": "workspace:*",
    "winston-transport": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@localsink/test-harness": "workspace:*",
    "winston": "catalog:"
  },
  "peerDependencies": {
    "winston": "catalog:"
  }
}
